  "keyFeatures": [
    "Reverse-mode automatic differentiation (backpropagation)",
    "Higher-order gradients via double backpropagation",
    "Pure Go implementation with no external dependencies",
    "N-dimensional tensor operations",
    "Built-in neural network layers (Linear, RNN, LSTM)",
    "Pre-built models (MLP, LSTM)",
    "Multiple optimizers: SGD, Momentum, Adam, AdamW",
    "NoGrad and TestMode context managers",
    "Numerical gradient checking for validation",
    "Computation graph visualization via Graphviz dot output"
  ],
